# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/gtw_platform

# ── Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_at_least_64_chars

# ── Server ─────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# ── Frontend ───────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Uploads ────────────────────────────────────────────────────────────────
# URL base do backend — usada para gerar URLs públicas dos arquivos enviados
BACKEND_URL=http://localhost:4000
# Diretório de armazenamento (padrão: ./uploads na raiz do processo)
# UPLOAD_DIR=/app/uploads

# ── Push notifications (PWA) ──────────────────────────────────────────────
# Gere o par de chaves uma única vez com: node scripts/generate-vapid-keys.js
# Sem essas variáveis, o envio de push fica desabilitado (resto do app funciona normalmente).
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:contato@gtwagencia.com.br
