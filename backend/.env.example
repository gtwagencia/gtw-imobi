# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/gtw_imobi

# ── Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_at_least_64_chars

# ── Server ─────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# ── Frontend ───────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Uploads ────────────────────────────────────────────────────────────────
# URL base do backend — usada para gerar URLs públicas dos arquivos enviados
BACKEND_URL=http://localhost:4000
# Diretório de armazenamento (padrão: ./uploads na raiz do processo)
# UPLOAD_DIR=/app/uploads

# ── WhatsApp Business API (WABA / API Oficial Meta) ───────────────────────
# Token de verificação do webhook — você escolhe qualquer string e configura
# tanto aqui quanto no Meta App Dashboard (Webhooks → Verify Token).
# Sem isso o Meta rejeita a verificação e NENHUMA mensagem é recebida.
WABA_VERIFY_TOKEN=coloque_aqui_um_token_secreto

# ── Meta App (Embedded Signup / WhatsApp Templates) ──────────────────────
# Obtenha em: developers.facebook.com → seu App → Configurações Básicas
# META_APP_ID: App ID do seu Meta App (público, pode aparecer no frontend)
# META_APP_SECRET: App Secret (NUNCA exponha no frontend)
# META_API_VERSION: versão da Graph API (ex: v19.0)
# META_EMBEDDED_SIGNUP_CONFIG_ID: ID da configuração do Embedded Signup
#   (Meta App → WhatsApp → Embedded Signup → ID da Configuração)
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v19.0
META_EMBEDDED_SIGNUP_CONFIG_ID=

# Chave Anthropic de fallback para geração de templates (quando o workspace
# não tem nenhum provedor de IA configurado)
# ANTHROPIC_API_KEY=

# ── Push notifications (PWA) ──────────────────────────────────────────────
# Gere o par de chaves uma única vez com: node scripts/generate-vapid-keys.js
# Sem essas variáveis, o envio de push fica desabilitado (resto do app funciona normalmente).
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:contato@gtwagencia.com.br
