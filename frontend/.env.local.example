NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Opcional: habilita o seletor de localização no mapa (cadastro de imóveis e empreendimentos).
# Sem essa chave, o sistema usa campos manuais de latitude/longitude.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Meta Embedded Signup — conectar WhatsApp Business do cliente diretamente no painel.
# NEXT_PUBLIC_META_APP_ID: App ID do Meta App (o mesmo valor de META_APP_ID no backend)
# NEXT_PUBLIC_META_EMBEDDED_SIGNUP_CONFIG_ID: ID da configuração do Embedded Signup
#   (Meta App → WhatsApp → Embedded Signup → ID da Configuração)
# Sem essas variáveis, o botão "Conectar WhatsApp Business" mostra mensagem de aviso.
NEXT_PUBLIC_META_APP_ID=
NEXT_PUBLIC_META_EMBEDDED_SIGNUP_CONFIG_ID=
